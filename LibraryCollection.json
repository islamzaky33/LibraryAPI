    {
      "name": "Get Book2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Lec 31 - Part 2 - check trust of response\r",
              "const responseB = pm.response.json();  //must put () after json\r",
              "pm.test(\"Response body add as request body\", function(){\r",
              "    pm.expect(responseB[0].book_name).to.eql(pm.collectionVariables.get(\"bookName\"));\r",
              "    pm.expect(responseB[0].isbn).to.eql(pm.collectionVariables.get(\"isbn\"));\r",
              "    pm.expect(responseB[0].aisle).to.eql(pm.collectionVariables.get(\"aisle\"));\r",
              "    pm.expect(responseB[0].author).to.eql(pm.collectionVariables.get(\"authorName\"));\r",
              "});\r",
              "\r",
              "//Lec 31 - Part 3 - Validate Scheam\r",
              "const schema = {\r",
              "  \"type\": \"array\",\r",
              "  \"items\": [\r",
              "    {\r",
              "      \"type\": \"object\",\r",
              "      \"properties\": {\r",
              "        \"book_name\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"isbn\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"aisle\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"author\": {\r",
              "          \"type\": \"string\"\r",
              "        }\r",
              "      },\r",
              "      \"required\": [\r",
              "        \"book_name\",\r",
              "        \"isbn\",\r",
              "        \"aisle\",\r",
              "        \"author\"\r",
              "      ]\r",
              "    }\r",
              "  ]\r",
              "}\r",
              "pm.test(\"Validate response body meet schema\", function(){\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
