  "item": [
    {
      "name": "Add Book2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();\r",
              "//extract responseBody from response and parsing from json to js object by json() method\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "//initial value to flag is false\r",
              "pm.collectionVariables.set(\"flag\", true);\r",
              "\r",
              "//Basic Validations (Validate status code, property existence and value)\r",
              "\r",
              "//Test Status code by three ways\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "})\r",
              "pm.test(\"Status code is success\", function(){\r",
              "    pm.response.to.be.success;\r",
              "})\r",
              "pm.test(\"Status code to be 200, 201 or 204\", function(){\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200,201,204]);\r",
              "})\r",
              "\r",
              "//Test property existence\r",
              "pm.test(\"Response to have property ID\", function(){\r",
              "    pm.expect(responseBody).to.have.property(\"ID\");\r",
              "})\r",
              "pm.test(\"Response to have property Msg\", function(){\r",
              "    pm.expect(responseBody).to.have.property(\"Msg\");\r",
              "})\r",
              "\r",
              "//Validate Header into response\r",
              "pm.test(\"Response to have Content-Type Header\", function(){\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "    //Header is part from Response not part from ResponseBody\r",
              "})\r",
              "//validate value of Headers Content-Type\r",
              "pm.test(\"Content-Type to be application/json\",function(){\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include\r",
              "    (\"json\");  //include json word\r",
              "})\r",
              "\r",
              "//Validate response time\r",
              "pm.test(\"Response time is less than 500ms\", function(){\r",
              "    pm.expect(pm.response.responseTime).be.below(500);\r",
              "})\r",
              "\r",
              "\r",
              "///////////////////////////// Lec 31 //////////////////////////////////\r",
              "//L31 - 1 - Convert all response to text, to check any word into response\r",
              "pm.test(\"Response body as text to contain successfully\",function(){\r",
              "    pm.expect(pm.response.text()).to.include(\"successfully\");\r",
              "})\r",
              "\r",
              "//L31 - 2 - Corelation ID to another request\r",
              "pm.collectionVariables.set(\"bookID\", responseBody.ID);\r",
              "\r",
              "/////////////////////////// Lec 32 /////////////////////////////////////\r",
              "//L32 - Part1 - Validate ID\r",
              "pm.test(\"ID logic validation\", function(){\r",
              "    const expectedID = requestBody.isbn+requestBody.aisle;\r",
              "    pm.expect(responseBody.ID).to.eql(expectedID);\r",
              "});\r",
              "\r",
              "//Lec 32 - Part 2\r",
              "//Test property Value\r",
              "pm.test(\"Response Msg to be successful\", function(){\r",
              "    try{\r",
              "        pm.expect(responseBody.Msg).to.eql(\"successfully added\");\r",
              "    }\r",
              "    catch(e){\r",
              "        cleanUp();\r",
              "    }\r",
              "})\r",
              "\r",
              "function cleanUp(){\r",
              "    pm.collectionVariables.set(\"flag\", true); \r",
              "    //flag is true when add duplicate book\r",
              "\r",
              "    const currentID = requestBody.isbn + requestBody.aisle;\r",
              "    //Put latest update ID into bookID collection variable \r",
              "    pm.collectionVariables.set(\"bookID\", currentID);\r",
              "\r",
              "    pm.execution.setNextRequest(\"Delete Book2\");\r",
              "    //control workflow to go Delete Book2 Request\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//first part from isbn is company code ... second part is random number\r",
              "//access Global Variable\r",
              "// const companyCode2 = pm.globals.set(\"companyCode2\", \"222\");\r",
              "const code = pm.globals.get(\"companyCode2\");\r",
              "\r",
              "//Math.random generate number between zero and one\r",
              "//Math.floor to remove decimal number ... then +1 to become from 1 to 1000\r",
              "// const random = Math.floor(Math.random()*1000)+1;\r",
              "\r",
              "//Another way to generate number\r",
              "//BuiltIn Random methods into Postman ...\r",
              "//... randomInt generate random number from 1 to 1000\r",
              "const random = pm.variables.replaceIn('{{$randomInt}}');\r",
              "\r",
              "//access isbn collection variable\r",
              "//isbn is concatenate code and random\r",
              "pm.collectionVariables.set(\"isbn\", code+random);\r",
              "\r",
              "// //Lec 31 - Part 2 -\r",
              "// // const random2 = Math.floor(Math.random()*1000)+1;\r",
              "// pm.collectionVariables.set(\"bookName\", \"Al-Ayam\");\r",
              "// pm.collectionVariables.set(\"aisle\", (Math.floor(Math.random()*1000)+1).toString());\r",
              "// // pm.collectionVariables.set(\"aisle\", \"1111\");\r",
              "// pm.collectionVariables.set(\"authorName\", \"Taha Hussien\");\r",
              "\r",
              "\r",
              "//Lec 32 - Part 1 - Data Provider\r",
              "// const random2 = Math.floor(Math.random()*1000)+1;\r",
              "pm.collectionVariables.set(\"bookName\", pm.iterationData.get(\"bookName\"));\r",
              "pm.collectionVariables.set(\"aisle\", (Math.floor(Math.random()*1000)+1).toString());\r",
              "// pm.collectionVariables.set(\"aisle\", \"1111\");\r",
              "pm.collectionVariables.set(\"authorName\", pm.iterationData.get(\"authorName\"));\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
